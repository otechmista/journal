      "name": "TecMundo",
      "type": "scrape",
      "enabled": true,
      "url": "https://www.tecmundo.com.br/",
      "selectors": {
        "item": "article:has(a[href*='.htm'])",
        "title": "a[href*='.htm']@title",
        "link": "a[href*='.htm']@href"
      },
      "crawl": {
        "depth": 1,
        "max_pages": 5,
        "same_origin_only": true,
        "delay_ms": 500
      }
    },
